{
  "type": "excalidraw",
  "version": 2,
  "source": "claude",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 200,
      "y": 20,
      "width": 300,
      "height": 40,
      "text": "Computation Graph: y = x²",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "subtitle",
      "type": "text",
      "x": 150,
      "y": 60,
      "width": 400,
      "height": 24,
      "text": "Every operation remembers its inputs",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#868e96"
    },
    {
      "id": "x_node",
      "type": "ellipse",
      "x": 100,
      "y": 150,
      "width": 80,
      "height": 80,
      "strokeColor": "#1971c2",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "x_label",
      "type": "text",
      "x": 115,
      "y": 170,
      "width": 50,
      "height": 40,
      "text": "x\n3.0",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "op_node",
      "type": "rectangle",
      "x": 280,
      "y": 160,
      "width": 60,
      "height": 60,
      "strokeColor": "#f08c00",
      "backgroundColor": "#ffd8a8",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "op_label",
      "type": "text",
      "x": 290,
      "y": 175,
      "width": 40,
      "height": 30,
      "text": "**2",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "y_node",
      "type": "ellipse",
      "x": 440,
      "y": 150,
      "width": 80,
      "height": 80,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "y_label",
      "type": "text",
      "x": 455,
      "y": 170,
      "width": 50,
      "height": 40,
      "text": "y\n9.0",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "arrow1",
      "type": "arrow",
      "x": 180,
      "y": 190,
      "width": 95,
      "height": 0,
      "strokeColor": "#1e1e1e",
      "strokeWidth": 2,
