      "points": [[0, 0], [95, 0]]
    },
    {
      "id": "arrow2",
      "type": "arrow",
      "x": 340,
      "y": 190,
      "width": 95,
      "height": 0,
      "strokeColor": "#1e1e1e",
      "strokeWidth": 2,
      "roughness": 0,
      "points": [[0, 0], [95, 0]]
    },
    {
      "id": "forward_label",
      "type": "text",
      "x": 230,
      "y": 120,
      "width": 150,
      "height": 20,
      "text": "Forward Pass →",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#2f9e44"
    },
    {
      "id": "grad_section",
      "type": "rectangle",
      "x": 80,
      "y": 280,
      "width": 460,
      "height": 120,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0
    },
    {
      "id": "grad_title",
      "type": "text",
      "x": 90,
      "y": 290,
      "width": 200,
      "height": 24,
      "text": "← Backward Pass",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#e03131"
    },
    {
      "id": "grad_x",
      "type": "text",
      "x": 100,
      "y": 320,
      "width": 180,
      "height": 60,
      "text": "x.grad = 6.0\n(dy/dx = 2x = 6)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#1971c2"
    },
    {
      "id": "grad_y",
      "type": "text",
      "x": 350,
      "y": 320,
      "width": 180,
      "height": 60,
      "text": "y.grad = 1.0\n(start here)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "strokeColor": "#2f9e44"
    },
    {
      "id": "insight",
      "type": "text",
      "x": 100,
      "y": 430,
      "width": 420,
      "height": 40,
      "text": "Gradient tells us: \"nudge x up → y goes up 6x faster\"",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "strokeColor": "#868e96"
    }
  ],
  "appState": {
    "viewBackgroundColor": "#ffffff"
  }
}
